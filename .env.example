# ─── Caddy ────────────────────────────────────────────────────────────────────
CADDY_ACME_EMAIL=admin@jobairo.com

# ─── Frontend (NEXT_PUBLIC_* are injected at build time) ──────────────────────
NEXT_PUBLIC_SITE_URL=https://jobairo.testapps.help
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_BACKEND_URL=https://jobairo.testapps.help
# Server-side only (NOT exposed to browser)
BACKEND_URL=http://backend:8000

# ─── Backend (FastAPI) ────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
JWT_SECRET=your-supabase-jwt-secret
CORS_ORIGINS=["https://jobairo.testapps.help","http://localhost:3000"]
ENVIRONMENT=production

# ─── Proxy (required for scraper in production) ───────────────────────────────
PROXY_URL=http://proxy.provider.com:8080
PROXY_USER=
PROXY_PASS=

# ─── SMTP alerts (scraper failure notifications) ──────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
ALERT_EMAIL=team@jobairo.com

# ─── Dozzle log viewer (auth managed by Dozzle users.yml, generated by CI/CD) ─
DOZZLE_USER=admin
DOZZLE_PASSWORD=your-dozzle-password-here

# ─── OAuth (set in Supabase dashboard, referenced here for docs) ──────────────
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
